# Narrative Alpha Agent environment template
#
# Copy this file to .env for local development.
# Never commit .env or real credentials.

# Runtime
NAA_ENV=development
NAA_DATABASE_PATH=naa.sqlite

# LangSmith / LangGraph tracing
# Set LANGSMITH_TRACING=true and LANGSMITH_API_KEY to trace graph runs.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=narrative-alpha-agent
LANGSMITH_WORKSPACE_ID=
LANGSMITH_RUN_NAME=narrative-alpha-agent
LANGSMITH_TAGS=naa,langgraph,narrative-replay

# LLM provider selection.
# Supported values:
# local, openai, anthropic, deepseek, openrouter, google, cohere, mistral,
# groq, together, xai, azure-openai, custom-openai-compatible
NAA_LLM_PROVIDER=local

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-3.5-haiku
OPENROUTER_APP_URL=https://github.com/BenjaminGrabow/narrative-alpha-agent
OPENROUTER_APP_NAME=Narrative Alpha Agent

# Google Gemini
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-1.5-flash

# Cohere
COHERE_API_KEY=
COHERE_MODEL=command-r

# Mistral
MISTRAL_API_KEY=
MISTRAL_BASE_URL=https://api.mistral.ai/v1
MISTRAL_MODEL=mistral-small-latest

# Groq
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant

# Together AI
TOGETHER_API_KEY=
TOGETHER_BASE_URL=https://api.together.xyz/v1
TOGETHER_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo

# xAI
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-2-latest

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_MODEL=

# Any OpenAI-compatible provider not listed above
CUSTOM_OPENAI_API_KEY=
CUSTOM_OPENAI_BASE_URL=
CUSTOM_OPENAI_MODEL=

# Future source connector credentials
TWITTER_BEARER_TOKEN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
NEWS_API_KEY=

# Alert notifiers
DISCORD_WEBHOOK_URL=
DISCORD_USERNAME=Narrative Alpha Agent
DISCORD_AVATAR_URL=
